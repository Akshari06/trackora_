rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // 2. Global helpers
    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function getTeacher() {
       return get(/databases/$(database)/documents/teachers/$(request.auth.uid)).data;
    }

    // 3. Teachers Profile
    match /teachers/{teacherId} {
      allow get: if isSignedIn() && request.auth.uid == teacherId;
      allow create: if isSignedIn() && request.auth.uid == teacherId;
      allow update: if isSignedIn() && request.auth.uid == teacherId;
    }

    // 4. Schools
    match /schools/{schoolId} {
      allow get: if isSignedIn() && getTeacher().schoolId == schoolId;
      allow create: if isSignedIn();
    }

    // 5. Shared Logic for School-scoped entities
    function isTeacherInSchool(schoolId) {
      return isSignedIn() && getTeacher().schoolId == schoolId;
    }

    // 6. Entities
    match /classes/{classId} {
      allow read: if isSignedIn() && isTeacherInSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isTeacherInSchool(incoming().schoolId);
      allow update: if isSignedIn() && isTeacherInSchool(existing().schoolId);
      allow delete: if isSignedIn() && isTeacherInSchool(existing().schoolId);
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && isTeacherInSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isTeacherInSchool(incoming().schoolId);
      allow update: if isSignedIn() && isTeacherInSchool(existing().schoolId);
      allow delete: if isSignedIn() && isTeacherInSchool(existing().schoolId);
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && isTeacherInSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isTeacherInSchool(incoming().schoolId);
      allow update: if isSignedIn() && isTeacherInSchool(existing().schoolId);
    }

    match /lessons/{lessonId} {
      allow read: if isSignedIn() && isTeacherInSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isTeacherInSchool(incoming().schoolId);
      allow update: if isSignedIn() && isTeacherInSchool(existing().schoolId);
      allow delete: if isSignedIn() && isTeacherInSchool(existing().schoolId);
    }

    match /assessments/{assessmentId} {
      allow read: if isSignedIn() && isTeacherInSchool(resource.data.schoolId);
      allow create: if isSignedIn() && isTeacherInSchool(incoming().schoolId);
      allow update: if isSignedIn() && isTeacherInSchool(existing().schoolId);
    }
  }
}
